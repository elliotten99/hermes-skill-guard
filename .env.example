SKILL_GUARD_DRY_RUN=true
SKILL_GUARD_ENFORCEMENT_MODE=audit
SKILL_GUARD_PREFLIGHT_TIMEOUT_MS=150
SKILL_GUARD_FAIL_OPEN=true
SKILL_GUARD_STATE_DIR=~/.hermes/skill-guard
SKILL_GUARD_CAPTURE_RAW_PAYLOADS=false
SKILL_GUARD_REDACTION_MODE=strict
SKILL_GUARD_MAX_FIELD_LENGTH=512
SKILL_GUARD_HASH_REDACTED_VALUES=true
SKILL_GUARD_TRACE_CACHE_TTL_MINUTES=10
SKILL_GUARD_TRACE_CACHE_MAX_ENTRIES=1000
SKILL_GUARD_EVENTS_TTL_DAYS=7
SKILL_GUARD_EVENTS_MAX_ROWS=10000
SKILL_GUARD_EVENTS_MAX_DB_MB=50
SKILL_GUARD_EVENTS_ROTATE_EVERY=100
SKILL_GUARD_ENABLED_INTENTS=
HERMES_VERSION=

# Optional custom rule file.
HSG_RULES_PATH=

# Optional metrics exporters.
HSG_OBSERVABILITY_ENABLED=false
HSG_OTEL_ENABLED=false
HSG_PROMETHEUS_ENABLED=false
HSG_PROMETHEUS_PORT=0

# Optional operator-assisted promotion scanner. Keep dry-run enabled first.
SKILL_GUARD_AUTO_PROMOTE_ENABLED=false
SKILL_GUARD_AUTO_PROMOTE_MIN_AGE_HOURS=168
SKILL_GUARD_AUTO_PROMOTE_NO_CONFLICTS=true
SKILL_GUARD_AUTO_PROMOTE_NO_DUPLICATES=false
SKILL_GUARD_AUTO_PROMOTE_DRY_RUN=true
